# Originals stay in the local iCloud workspace. Git stores only publishable
# optimized media from public/media/.
media-originals/*
!media-originals/README.md

# The repository contains only the published site and its operating docs.
# Personal OS material and publication drafts stay outside this repository.
raw/
wiki/
private/
work/
content-drafts/

# The public manifest is committed; local incremental-build state is not.
generated/*
!generated/media-manifest.json

# Local editor and diagnostic output.
.idea/
.vscode/
*.log

